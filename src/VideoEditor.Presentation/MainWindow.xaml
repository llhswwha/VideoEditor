                                                <Button Content="🔊 100%" Name="BtnVolume100" Height="32" Margin="4,0" FontSize="12" Click="BtnVolume100_Click"/>
                                                <Button Content="📢 150%" Name="BtnVolume150" Height="32" Margin="4,0" FontSize="12" Click="BtnVolume150_Click"/>
