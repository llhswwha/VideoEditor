                                                    <ComboBoxItem Content="AAC (推荐)"/>
                                                    <ComboBoxItem Content="MP3"/>
                                                    <ComboBoxItem Content="WAV (无损)"/>
                                                    <ComboBoxItem Content="FLAC (无损)"/>
                                                    <ComboBoxItem Content="复制原格式"/>
                                                </ComboBox>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="比特率" FontSize="13" Margin="0,0,0,6"/>
                                                <ComboBox Name="cboBitrate" SelectedIndex="2" FontSize="12" Height="32">
                                                    <ComboBoxItem Content="128 kbps"/>
                                                    <ComboBoxItem Content="192 kbps (推荐)"/>
                                                    <ComboBoxItem Content="256 kbps"/>
                                                    <ComboBoxItem Content="320 kbps (高音质)"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>
                                    </GroupBox>
                                    
                                    <!-- 音频操作 -->
                                    <GroupBox Header="⚙️ 音频操作" Margin="0,0,0,16" FontSize="14" FontWeight="SemiBold">
                                        <StackPanel Margin="12">
                                            <Border Background="{DynamicResource Brush.ButtonLightBlue}" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                                <StackPanel>
                                                    <TextBlock Text="📤 提取音频" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>
                                                    <TextBlock Text="从视频文件中提取音频轨道,支持多种格式" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,10"/>
                                                    <Button Content="开始提取" Name="BtnExtractAudio" Height="32" FontSize="12" Style="{StaticResource ButtonInfoStyle}" Click="BtnExtractAudio_Click"/>
                                                </StackPanel>
                                            </Border>
                                            
                                            <Border Background="{DynamicResource Brush.ButtonLightOrange}" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                                <StackPanel>
                                                    <TextBlock Text="🔄 替换音频" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>
                                                    <TextBlock Text="用新的音频文件替换视频中的原音频" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,10"/>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Name="txtAudioFilePath" Text="选择音频文件..." FontSize="12" Height="32" VerticalContentAlignment="Center" IsReadOnly="True"/>
                                                        <Button Grid.Column="1" Content="📁 浏览" Name="BtnBrowseAudioFile" Width="70" Height="32" Margin="8,0,0,0" FontSize="12" Click="BtnBrowseAudioFile_Click"/>
                                                    </Grid>
                                                    <Button Content="开始替换" Name="BtnReplaceAudio" Height="32" FontSize="12" Style="{StaticResource ButtonWarningStyle}" Click="BtnReplaceAudio_Click"/>
                                                </StackPanel>
                                            </Border>
                                            
                                            <Border Background="{DynamicResource Brush.ButtonLightRed}" CornerRadius="4" Padding="12">
                                                <StackPanel>
                                                    <TextBlock Text="🗑️ 删除音频" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>
                                                    <TextBlock Text="从视频中完全移除音频轨道,仅保留画面" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,10"/>
                                                    <Button Content="删除音频" Name="BtnRemoveAudio" Height="32" FontSize="12" Style="{StaticResource ButtonDangerStyle}" Click="BtnRemoveAudio_Click"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </GroupBox>
                                    
                                    <!-- 操作按钮 -->
                                    <Button Content="✓ 应用所有音频设置" Name="BtnApplyAudioSettings" Height="36" Margin="0,0,0,0" FontSize="13" FontWeight="Bold" Style="{StaticResource ButtonSuccessStyle}" Cursor="Hand" Click="BtnApplyAudioSettings_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem><!-- ==================== 标签页10：图片/GIF ==================== -->
                        <TabItem Header=" 📸 图/GIF">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                                <StackPanel>
                                    <!-- 提取视频帧 -->
                                    <GroupBox Header="📸 提取视频帧" Margin="0,0,0,16" FontSize="14" FontWeight="SemiBold">
                                        <StackPanel Margin="12">
                                            <TextBlock Text="提取时间点" FontSize="13" Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Name="txtExtractTime" Text="00:00:00.000" MaxLength="12" FontSize="12" Height="32" FontFamily="Consolas" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                                                <Button Grid.Column="1" Name="BtnUseCurrentTimeForExtract" Content="⏱️ 当前时间" Width="100" Height="32" Margin="8,0,0,0" FontSize="12" Click="BtnUseCurrentTimeForExtract_Click"/>
                                            </Grid>
                                            
                                            <TextBlock Text="图片格式" FontSize="13" Margin="0,0,0,6"/>
                                            <ComboBox Name="cboPictureFormat" SelectedIndex="0" FontSize="12" Height="32" Margin="0,0,0,12">
                                                <ComboBoxItem Content="PNG (无损)"/>
                                                <ComboBoxItem Content="JPG (压缩)"/>
                                                <ComboBoxItem Content="BMP"/>
                                                <ComboBoxItem Content="WebP"/>
                                            </ComboBox>
                                            
                                            <Button Name="BtnExtractFrame" Content="📸 提取当前帧" Height="32" Margin="0,0,0,0" FontSize="12" Style="{StaticResource ButtonInfoStyle}" Click="BtnExtractFrame_Click"/>
                                        </StackPanel>
                                    </GroupBox>
                                    
                                    <!-- 制作GIF动图 -->
                                    <GroupBox Header="🎞️ 制作GIF动图" Margin="0,0,0,16" FontSize="14" FontWeight="SemiBold">
                                        <StackPanel Margin="12">
                                            <TextBlock Text="时间范围" FontSize="13" Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="开始" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Name="txtGifStartTime" Text="00:00:00.000" MaxLength="12" FontSize="12" Height="32" FontFamily="Consolas" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                                                <Button Grid.Column="2" Name="BtnUseInPointForGif" Content="I" Width="32" Height="32" Margin="4,0,0,0" FontSize="12" FontWeight="Bold" Style="{StaticResource ButtonInfoOutlineStyle}" ToolTip="使用入点时间" Click="BtnUseInPointForGif_Click"/>
                                                <TextBlock Grid.Column="3" Text="结束" FontSize="13" Margin="12,0,8,0" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="4" Name="txtGifEndTime" Text="00:00:05.000" MaxLength="12" FontSize="12" Height="32" FontFamily="Consolas" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                                                <Button Grid.Column="5" Name="BtnUseOutPointForGif" Content="O" Width="32" Height="32" Margin="4,0,0,0" FontSize="12" FontWeight="Bold" Style="{StaticResource ButtonWarningOutlineStyle}" ToolTip="使用出点时间" Click="BtnUseOutPointForGif_Click"/>
                                            </Grid>
                                            
                                            <TextBlock Text="参数设置" FontSize="13" Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="FPS" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Name="txtGifFPS" Text="10" MaxLength="2" FontFamily="Consolas" FontSize="12" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="宽度" FontSize="13" Margin="16,0,8,0" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="3" Name="txtGifWidth" Text="480" MaxLength="4" FontFamily="Consolas" FontSize="12" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                                            </Grid>
                                            
                                            <TextBlock Text="质量模式" FontSize="13" Margin="0,0,0,6"/>
                                            <ComboBox Name="cboGifQuality" SelectedIndex="1" FontSize="12" Height="32" Margin="0,0,0,12">
                                                <ComboBoxItem Content="低质量（小文件）"/>
                                                <ComboBoxItem Content="中等质量（推荐）"/>
                                                <ComboBoxItem Content="高质量（大文件）"/>
                                            </ComboBox>
                                            
                                            <Button Name="BtnMakeGif" Content="🎞️ 制作GIF" Height="32" Margin="0,0,0,0" FontSize="12" Style="{StaticResource ButtonPurpleStyle}" Click="BtnMakeGif_Click"/>
                                        </StackPanel>
                                    </GroupBox>
                                    
                                    <!-- 图片拼接 -->
                                    <GroupBox Header="🎨 图片拼接" Margin="0,0,0,16" FontSize="14" FontWeight="SemiBold">
                                        <StackPanel Margin="12">
                                            <TextBlock Text="选择多张图片进行拼接" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,10"/>
                                            <UniformGrid Rows="1" Columns="2">
                                                <Button Name="BtnHorizontalConcat" Content="➡️ 水平拼接" Height="32" Margin="4" FontSize="12" Style="{StaticResource ButtonInfoStyle}" Click="BtnHorizontalConcat_Click"/>
                                                <Button Name="BtnVerticalConcat" Content="⬇️ 垂直拼接" Height="32" Margin="4" FontSize="12" Style="{StaticResource ButtonInfoStyle}" Click="BtnVerticalConcat_Click"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </GroupBox>
                                    
                                    <!-- 说明 -->
                                    <GroupBox Header="💡 使用说明" Margin="0,0,0,16" FontSize="14" FontWeight="SemiBold">
                                        <StackPanel Margin="12">
                                            <TextBlock Text="• 提取帧：从视频中抓取指定时间点的图片，支持多种格式" FontSize="12" Margin="0,4" TextWrapping="Wrap"/>
                                            <TextBlock Text="• 制作GIF：将视频片段转换为动图，可调整FPS和分辨率" FontSize="12" Margin="0,4" TextWrapping="Wrap"/>
                                            <TextBlock Text="• 图片拼接：合并多张图片为一张，支持水平/垂直拼接" FontSize="12" Margin="0,4" TextWrapping="Wrap"/>
                                            <TextBlock Text="• FFmpeg参数：使用scale、fps、palettegen等滤镜优化GIF质量" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,8,0,0" FontFamily="Consolas"/>
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem><!-- ==================== 标签页11：去重 ==================== -->
                        <TabItem Header=" 🎯 去重">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                                <StackPanel>
                                    <!-- 去重模式 -->
                                    <GroupBox Header="🎯 去重模式" Margin="0,0,0,16" FontSize="14" FontWeight="SemiBold">
                                        <StackPanel Margin="12">
                                            <TextBlock Text="选择去重强度" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,10"/>
                                            <UniformGrid Rows="1" Columns="4">
                                                <RadioButton Content="🚫 关闭" Name="RadioOffMode" IsChecked="True" FontSize="13" Margin="4,8" ToolTip="不进行去重处理" HorizontalAlignment="Center"/>
                                                <RadioButton Content="⚡ 轻度" Name="RadioLightMode" FontSize="13" Margin="4,8" ToolTip="亮度±3%, 对比度±3%" HorizontalAlignment="Center"/>
                                                <RadioButton Content="⚡⚡ 中度" Name="RadioMediumMode" FontSize="13" Margin="4,8" ToolTip="亮度±5%, 对比度±5%, 噪点" HorizontalAlignment="Center"/>
                                                <RadioButton Content="⚡⚡⚡ 重度" Name="RadioHeavyMode" FontSize="13" Margin="4,8" ToolTip="综合处理+模糊+裁剪" HorizontalAlignment="Center"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </GroupBox>
                                    
                                    <!-- 色彩调整 -->
                                    <GroupBox Header="🎨 色彩调整" Margin="0,0,0,16" FontSize="14" FontWeight="SemiBold">
                                        <StackPanel Margin="12">
                                            <!-- 亮度 -->
                                            <TextBlock Text="亮度调整" FontSize="13" Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0" Name="sliderBrightness" Minimum="-10" Maximum="10" Value="5" TickFrequency="1" Height="28" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Text="{Binding ElementName=sliderBrightness, Path=Value, StringFormat={}{0:F0}%}" FontSize="12" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="8,0,0,0" IsReadOnly="True"/>
                                            </Grid>
                                            
                                            <!-- 对比度 -->
                                            <TextBlock Text="对比度调整" FontSize="13" Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0" Name="sliderContrast" Minimum="-10" Maximum="10" Value="5" TickFrequency="1" Height="28" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Text="{Binding ElementName=sliderContrast, Path=Value, StringFormat={}{0:F0}%}" FontSize="12" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="8,0,0,0" IsReadOnly="True"/>
                                            </Grid>
                                            
                                            <!-- 饱和度 -->
                                            <TextBlock Text="饱和度调整" FontSize="13" Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0" Name="sliderSaturation" Minimum="-10" Maximum="10" Value="5" TickFrequency="1" Height="28" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Text="{Binding ElementName=sliderSaturation, Path=Value, StringFormat={}{0:F0}%}" FontSize="12" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="8,0,0,0" IsReadOnly="True"/>
                                            </Grid>
                                        </StackPanel>
                                    </GroupBox>
                                    
                                    <!-- 高级效果 -->
                                    <GroupBox Header="⚙️ 高级效果" Margin="0,0,0,16" FontSize="14" FontWeight="SemiBold">
                                        <StackPanel Margin="12">
                                            <!-- 噪点 -->
                                            <TextBlock Text="噪点强度" FontSize="13" Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0" Name="sliderNoise" Minimum="0" Maximum="30" Value="10" TickFrequency="5" Height="28" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Text="{Binding ElementName=sliderNoise, Path=Value, StringFormat={}{0:F0}}" FontSize="12" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="8,0,0,0" IsReadOnly="True"/>
                                            </Grid>
                                            
                                            <!-- 模糊 -->
                                            <TextBlock Text="模糊程度" FontSize="13" Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0" Name="sliderBlur" Minimum="0" Maximum="10" Value="2" TickFrequency="1" Height="28" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Text="{Binding ElementName=sliderBlur, Path=Value, StringFormat={}{0:F0}}" FontSize="12" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="8,0,0,0" IsReadOnly="True"/>
                                            </Grid>
                                            
                                            <!-- 边缘裁剪 -->
                                            <TextBlock Text="边缘裁剪" FontSize="13" Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0" Name="sliderCropEdge" Minimum="0" Maximum="10" Value="2" TickFrequency="1" Height="28" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Text="{Binding ElementName=sliderCropEdge, Path=Value, StringFormat={}{0:F0}px}" FontSize="12" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="8,0,0,0" IsReadOnly="True"/>
                                            </Grid>
                                        </StackPanel>
                                    </GroupBox>
                                    
                                    <!-- 应用按钮 -->
                                    <Button Content="✓ 应用去重设置" Name="ApplyDeduplicateButton" Height="36" Margin="0,0,0,16" FontSize="13" FontWeight="Bold" Style="{StaticResource ButtonSuccessStyle}" Cursor="Hand" Click="ApplyDeduplicateButton_Click"/>
                                    
                                    <!-- 说明 -->
                                    <GroupBox Header="💡 使用说明" Margin="0,0,0,16" FontSize="14" FontWeight="SemiBold">
                                        <StackPanel Margin="12">
                                            <TextBlock Text="• 轻度处理：微调亮度和对比度，适用于一般防检测需求" FontSize="12" Margin="0,4" TextWrapping="Wrap"/>
                                            <TextBlock Text="• 中度处理：增加噪点和色彩变化，更强的去重效果" FontSize="12" Margin="0,4" TextWrapping="Wrap"/>
                                            <TextBlock Text="• 重度处理：综合应用所有效果，最强去重但影响画质" FontSize="12" Margin="0,4" TextWrapping="Wrap"/>
                                            <TextBlock Text="• FFmpeg参数：通过eq、noise、boxblur等滤镜实现" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,8,0,0" FontFamily="Consolas"/>
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem><!-- ==================== 标签页12：时间码批处理 ==================== -->
                        <TabItem Header=" ⏱️ 时码">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                                <StackPanel>
                                    <!-- 时间码输入 -->
                                    <GroupBox Header="📥 时间码输入" Margin="0,0,0,16" FontSize="14" FontWeight="SemiBold">
                                        <StackPanel Margin="12">
                                            <TextBlock Text="粘贴AI生成的时间码（支持多种格式）" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,8"/>
                                            <TextBox Name="txtTimecodeInput" Height="200" FontSize="12" FontFamily="Consolas"
                                                    TextWrapping="Wrap" AcceptsReturn="True" 
                                                    VerticalScrollBarVisibility="Auto"
                                                    Padding="8"
                                                    Background="{DynamicResource Brush.InputBackground}"
                                                    Foreground="{DynamicResource Brush.InputForeground}"
                                                    BorderBrush="{DynamicResource Brush.InputBorder}"
                                                    BorderThickness="1"
                                                    ToolTip="支持格式：00:01:23.456 - 00:02:34.567 或 [1:23.456, 2:34.567]"
                                                    Margin="0,0,0,12">
                                            </TextBox>
                                            
                                            <UniformGrid Rows="1" Columns="2">
                                                <Button Content="📂 加载示例" Name="BtnLoadTimecodeExample" Height="32" Margin="4" FontSize="12" Click="BtnLoadTimecodeExample_Click"/>
                                                <Button Content="🗑️ 清空" Name="BtnClearTimecodeInput" Height="32" Margin="4" FontSize="12" Style="{StaticResource ButtonDangerOutlineStyle}" Click="BtnClearTimecodeInput_Click"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </GroupBox>
                                    
                                    <!-- 批处理选项 -->
                                    <GroupBox Header="⚙️ 批处理选项" Margin="0,0,0,16" FontSize="14" FontWeight="SemiBold">
                                        <StackPanel Margin="12">
                                            <CheckBox Content="保留原始编码（不重新编码）" Name="chkKeepOriginalCodec" IsChecked="True" FontSize="13" Margin="0,6"/>
                                        </StackPanel>
                                    </GroupBox>
                                    
                                    <!-- 时间码输出预览 -->
                                    <GroupBox Header="📤 时间码提取预览" Margin="0,0,0,16" FontSize="14" FontWeight="SemiBold">
                                        <StackPanel Margin="12">
                                            <TextBlock Name="txtTimecodeCount"
                                                       Text="解析结果（共 0 个片段）"
                                                       FontSize="13"
                                                       Margin="0,0,0,8"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.TextPrimary}"/>
                                            <TextBox Name="txtTimecodeOutput" Height="150" FontSize="12" FontFamily="Consolas"
                                                    TextWrapping="Wrap" IsReadOnly="True"
                                                    VerticalScrollBarVisibility="Auto"
                                                    Padding="8"
                                                    Background="{DynamicResource Brush.PanelAltBackground}"
                                                    BorderBrush="{DynamicResource Brush.PanelBorder}"
                                                    BorderThickness="1"
                                                    Margin="0,0,0,12"/>
                                            
                                            <Button Content="🔍 解析时间码" Name="BtnParseTimecode" Height="32" Margin="4" FontSize="12" Style="{StaticResource ButtonInfoStyle}" Click="BtnParseTimecode_Click"/>
                                        </StackPanel>
                                    </GroupBox>
                                    
                                    <!-- 操作按钮 -->
                                    <UniformGrid Rows="1" Columns="2" Margin="0,0,0,0">
                                        <Button Content="✂️ 开始批量分割" Name="BtnSplitByTimecode" Height="36" Margin="4,0" FontSize="13" FontWeight="Bold" Style="{StaticResource ButtonWarningStyle}" Cursor="Hand" Click="BtnSplitByTimecode_Click"/>
                                        <Button Content="🔗 分割并合并" Name="BtnSplitAndMerge" Height="36" Margin="4,0" FontSize="13" FontWeight="Bold" Style="{StaticResource ButtonSuccessStyle}" Cursor="Hand" Click="BtnSplitAndMerge_Click"/>
                                    </UniformGrid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        
                    </TabControl>
                </Border>
            </Grid>
            
            <!-- 分隔条2 -->
            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="{DynamicResource Brush.SplitterBackground}"/>
            
            <!-- ==================== 右侧列（两区域分割）==================== -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.2*" MinHeight="300"/>   <!-- 右上：输出设置（扩展） -->
                    <RowDefinition Height="5"/>                      <!-- 分隔符 -->
                    <RowDefinition Height="0.8*" MinHeight="200"/>   <!-- 右下：输出信息（命令终端） -->
                </Grid.RowDefinitions>
                
                <!-- 右上：输出设置区域（扩展版） -->
                <Border Grid.Row="0"
                        Background="{DynamicResource Brush.PanelBackground}"
                        BorderBrush="{DynamicResource Brush.PanelBorder}"
                        BorderThickness="1,0,0,1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12">
                            <!-- 标题 -->
                            <Border Background="{DynamicResource Brush.PanelAltBackground}"
                                    BorderBrush="{DynamicResource Brush.PanelBorder}"
                                    BorderThickness="0,0,0,2"
                                    Padding="10,8"
                                    Margin="-12,-12,-12,12">
                                <TextBlock Text="⚙️ 输出设置"
                                           FontWeight="Bold"
                                           FontSize="15"
                                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                            </Border>
                            
                            <!-- 输出路径 -->
                            <GroupBox Header="📁 输出路径" Margin="0,0,0,12" FontSize="13">
                                <StackPanel Margin="8">
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Name="OutputPathBox" Text="D:\Video\Output" 
                                                 FontSize="11" Height="30" VerticalContentAlignment="Center"/>
                                        <Button Name="BrowseOutputPathButton" Grid.Column="1" Content="📂 浏览" Width="60" Height="30"
                                                Margin="5,0,0,0" FontSize="11" Click="BrowseOutputPathButton_Click"/>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>
                            
                            <!-- 文件命名 -->
                            <GroupBox Header="📝 文件命名" Margin="0,0,0,12" FontSize="13">
                                <StackPanel Margin="8">
                                    <RadioButton Name="OriginalNameRadio" Content="原文件名_处理" IsChecked="True" Margin="0,8,0,5" FontSize="12"/>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <RadioButton Name="CustomPrefixRadio" Content="自定义前缀:" Grid.Column="0" Margin="0,0,8,0" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Name="CustomPrefixBox" Height="28" FontSize="11" VerticalContentAlignment="Center"/>
                                    </Grid>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <RadioButton Name="CustomSuffixRadio" Content="自定义后缀:" Grid.Column="0" Margin="0,0,8,0" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Name="CustomSuffixBox" Height="28" FontSize="11" VerticalContentAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>
                            
                            <!-- 编码设置 -->
                            <GroupBox Header="🎬 编码设置" Margin="0,0,0,12" FontSize="13">
                                <StackPanel Margin="8">
                                    <TextBlock Text="输出格式:" FontSize="12" Margin="0,8,0,5"/>
                                    <ComboBox Name="OutputFormatBox" SelectedIndex="0" FontSize="11" Height="30">
                                        <ComboBoxItem Content="MP4 (推荐)"/>
                                        <ComboBoxItem Content="MKV"/>
                                        <ComboBoxItem Content="AVI"/>
                                        <ComboBoxItem Content="MOV"/>
                                    </ComboBox>
                                    
                                    <TextBlock Text="视频编码器:" FontSize="12" Margin="0,10,0,5"/>
                                    <RadioButton Name="CopyCodecRadio" Content="快速复制 (-c copy) 无损、速度快" IsChecked="True" FontSize="11" Margin="0,5"/>
                                    <RadioButton Name="H264CodecRadio" Content="H.264 (libx264) 兼容性好" FontSize="11" Margin="0,5"/>
                                    <RadioButton Name="H265CodecRadio" Content="H.265 (libx265) 体积小" FontSize="11" Margin="0,5"/>
                                    
                                    <TextBlock Text="质量设置 (CRF):" FontSize="12" Margin="0,10,0,5"/>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider Name="QualitySlider" Minimum="18" Maximum="28" Value="23" 
                                                TickFrequency="1" IsSnapToTickEnabled="True" Height="24"/>
                                        <TextBlock Grid.Column="1" Name="QualityValueText" 
                                                   Text="{Binding ElementName=QualitySlider, Path=Value, StringFormat={}{0:F0}}" 
                                                   FontFamily="Consolas" FontSize="12" Margin="10,0,0,0" 
                                                   VerticalAlignment="Center" Width="25"/>
                                    </Grid>
                                    <TextBlock Text="18=高质量 | 23=平衡 | 28=高压缩"
                                               FontSize="10"
                                               Foreground="{DynamicResource Brush.TextSecondary}"
                                               HorizontalAlignment="Center"/>
                                    
                                    <TextBlock Text="音频编码:" FontSize="12" Margin="0,10,0,5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Name="AudioCodecBox" Grid.Column="0" SelectedIndex="0" FontSize="11" Height="30" Margin="0,0,5,0">
                                            <ComboBoxItem Content="AAC"/>
                                            <ComboBoxItem Content="MP3"/>
                                            <ComboBoxItem Content="复制"/>
                                        </ComboBox>
                                        <ComboBox Name="AudioBitrateBox" Grid.Column="1" SelectedIndex="2" FontSize="11" Height="30" Margin="5,0,0,0">
                                            <ComboBoxItem Content="96 kbps"/>
                                            <ComboBoxItem Content="128 kbps"/>
                                            <ComboBoxItem Content="192 kbps"/>
                                            <ComboBoxItem Content="256 kbps"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>
                            
                            <!-- 高级选项 -->
                            <GroupBox Header="🔧 高级选项" Margin="0,0,0,12" FontSize="13">
                                <StackPanel Margin="8">
                                    <CheckBox Name="UseCommandPromptForCropCheckBox"
                                              Content="通过命令提示符执行"
                                              FontSize="11"
                                              Margin="0,8,0,5"
                                              ToolTip="勾选后裁剪操作将生成FFmpeg命令并在命令提示符中执行，而不是直接执行"/>

                                    <TextBlock Text="自定义FFmpeg参数:" FontSize="12" Margin="0,10,0,5"/>
                                    <TextBox Name="CustomArgsBox" Height="60" FontFamily="Consolas"
                                             FontSize="10" TextWrapping="Wrap" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto">
                                    </TextBox>
                                </StackPanel>
                            </GroupBox>

                            <!-- 高级提示 -->
                            <GroupBox Header="💡 高级使用说明" Margin="0,0,0,12" FontSize="13">
                                <StackPanel Margin="8">
                                    <TextBlock Text="• H.264: 通用性最好，几乎所有设备都支持" FontSize="11" Margin="0,2" TextWrapping="Wrap"/>
                                    <TextBlock Text="• H.265: 同等质量下文件更小，但编码慢，部分设备不支持" FontSize="11" Margin="0,2" TextWrapping="Wrap"/>
                                    <TextBlock Text="• CRF范围 18-28：数值越低画质越好，但文件越大" FontSize="11" Margin="0,2" TextWrapping="Wrap"/>
                                    <TextBlock Text="• 自定义参数会追加到FFmpeg命令末尾，请谨慎使用" FontSize="11" Foreground="{DynamicResource Brush.ButtonDanger}" Margin="4,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                
                <!-- 分隔符 -->
                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Background="{DynamicResource Brush.SplitterBackground}" Height="5"/>
                
                <!-- 右下：输出信息区域（命令终端 + 文件信息） -->
                <Border x:Name="OutputInfoContainer"
                        Grid.Row="2"
                        Background="{DynamicResource Brush.PanelBackground}"
                        BorderBrush="{DynamicResource Brush.PanelBorder}"
                        BorderThickness="1,0,0,0">
                    <TabControl Name="OutputInfoTabs" SelectedIndex="0">
                        <!-- 标签页1：执行日志 -->
                        <TabItem x:Name="ExecutionLogTabItem" Header="⚙️ 执行日志">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 日志输出窗口 -->
                                <Border Grid.Row="0"
                                        Background="#1E1E1E"
                                        BorderBrush="#37474F"
                                        BorderThickness="1">
                                    <ScrollViewer Name="LogScrollViewer" 
                                                  VerticalScrollBarVisibility="Auto"
                                                  Padding="0"
                                                  Background="#1E1E1E">
                                        <TextBox Name="LogOutputBox"
                                                 FontFamily="Consolas" 
                                                 FontSize="10"
                                                 Background="#1E1E1E" 
                                                 Foreground="#E0E0E0"
                                                 BorderThickness="0" 
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap" 
                                                 Padding="10"
                                                 VerticalAlignment="Stretch"
                                                 Style="{x:Null}"
                                                 Text="$ 等待执行命令...&#x0a;&#x0a;提示: 点击上方'开始处理'按钮开始执行">
                                            <TextBox.Template>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border x:Name="border" Background="#1E1E1E" BorderBrush="Transparent" BorderThickness="0">
                                                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" Background="#1E1E1E"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </TextBox.Template>
                                        </TextBox>
                                    </ScrollViewer>
                                </Border>
                                
                                <!-- 进度条 -->
                                <Border Grid.Row="1"
                                        Background="#2D2D30"
                                        Padding="8,5">
                                    <StackPanel>
                                        <!-- 总进度 -->
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Text="总进度:"
                                                       Foreground="#999" 
                                                       Margin="0,0,8,0" VerticalAlignment="Center" FontSize="10"/>
                                            <ProgressBar Grid.Column="1" Name="ExecutionProgressBar" 
                                                         Height="12" Minimum="0" Maximum="100" Value="0"
                                                         Foreground="#4CAF50"
                                                         Background="#37474F"
                                                         BorderBrush="#37474F"
                                                         Style="{x:Null}">
                                                <ProgressBar.Template>
                                                    <ControlTemplate TargetType="ProgressBar">
                                                        <Border x:Name="PART_Track" Background="#37474F" BorderThickness="0" CornerRadius="2">
                                                            <Border x:Name="PART_Indicator" Background="#4CAF50" HorizontalAlignment="Left" CornerRadius="2"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </ProgressBar.Template>
                                            </ProgressBar>
                                            <TextBlock Grid.Column="2" Name="ProgressInfoText" 
                                                       Text="0/0 | 0%" 
                                                       Foreground="#999" Margin="8,0,0,0"
                                                       FontFamily="Consolas" FontSize="10"
                                                       VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- 单个文件进度 -->
                                        <StackPanel Margin="0,2,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="当前文件:"
                                                           Foreground="#999" 
                                                           Margin="0,0,8,0" VerticalAlignment="Center" FontSize="10"/>
                                                <ProgressBar Grid.Column="1" Name="FileProgressBar" 
                                                             Height="12" Minimum="0" Maximum="100" Value="0"
                                                             Foreground="#2196F3"
                                                             Background="#37474F"
                                                             BorderBrush="#37474F"
                                                             Style="{x:Null}">
                                                    <ProgressBar.Template>
                                                        <ControlTemplate TargetType="ProgressBar">
                                                            <Border x:Name="PART_Track" Background="#37474F" BorderThickness="0" CornerRadius="2">
                                                                <Border x:Name="PART_Indicator" Background="#2196F3" HorizontalAlignment="Left" CornerRadius="2"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </ProgressBar.Template>
                                                </ProgressBar>
                                                <TextBlock Grid.Column="2" Name="FileProgressText" 
                                                           Text="0.0%" 
                                                           Foreground="#999" Margin="8,0,0,0"
                                                           FontFamily="Consolas" FontSize="10"
                                                           VerticalAlignment="Center"/>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="当前文件用时:"
                                                           Foreground="#999"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Center"
                                                           FontSize="10"/>
                                                <TextBlock Name="FileElapsedTimeText"
                                                           Text="00:00"
                                                           Foreground="#999"
                                                           FontFamily="Consolas"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="   预计总用时:"
                                                           Foreground="#999"
                                                           Margin="12,0,8,0"
                                                           VerticalAlignment="Center"
                                                           FontSize="10"/>
                                                <TextBlock Name="FileEstimatedTotalTimeText"
                                                           Text="--:--"
                                                           Foreground="#999"
                                                           FontFamily="Consolas"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="   预计剩余:"
                                                           Foreground="#999"
                                                           Margin="12,0,8,0"
                                                           VerticalAlignment="Center"
                                                           FontSize="10"/>
                                                <TextBlock Name="FileEstimatedRemainingTimeText"
                                                           Text="--:--"
                                                           Foreground="#999"
                                                           FontFamily="Consolas"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                
                                <!-- 控制按钮 -->
                                <Border Grid.Row="2"
                                        Background="#2D2D30"
                                        BorderBrush="#3F3F46" 
                                        BorderThickness="0,1,0,0"
                                        Padding="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- 状态指示 -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Name="StatusIndicator"
                                                    Width="10"
                                                    Height="10" 
                                                    Background="#4CAF50"
                                                    CornerRadius="5"
                                                    Margin="0,0,8,0"/>
                                            <TextBlock Name="StatusText"
                                                       Text="就绪" 
                                                       FontSize="11"
                                                       Foreground="#E0E0E0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <!-- 操作按钮 -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Name="BtnSaveLog" Content="💾 保存日志" Width="90" Height="28" 
                                                    Margin="3" FontSize="10" Click="BtnSaveLog_Click" ToolTip="将执行日志保存到文件"/>
                                            <Button Name="BtnClearLog" Content="🗑️ 清空" Width="70" Height="28" 
                                                    Margin="3" FontSize="10" Click="BtnClearLog_Click" ToolTip="清空执行日志"/>
                                            <Button Name="StopExecutionButton" Content="⏹ 停止" 
                                                    Width="70" Height="28" Margin="3" FontSize="10"
                                                    Style="{StaticResource ButtonDangerStyle}" 
                                                    IsEnabled="False" Click="StopExecutionButton_Click" ToolTip="停止当前执行的任务"/>
                </StackPanel>
            </Grid>
        </Border>
                            </Grid>
                        </TabItem>
                        
                        <!-- 标签页2：命令预览 -->
                        <TabItem x:Name="CommandPreviewTabItem" Header="📝 命令预览">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 命令显示区 -->
                                <Border Grid.Row="0"
                                        Background="#263238"
                                        Padding="10">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#263238">
                                        <StackPanel>
                                            <TextBlock Text="即将执行的 FFmpeg 命令:" 
                                                       Foreground="#999" FontSize="11" Margin="0,0,0,5"/>
                                            
                                            <Border Background="#1E1E1E"
                                                    BorderBrush="#37474F" 
                                                    BorderThickness="1" Padding="10" CornerRadius="3">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300" Background="#1E1E1E">
                                                    <TextBox Name="CommandPreviewBox"
                                                             Text="ffmpeg -i input.mp4&#x0a;  -ss 00:00:10.000&#x0a;  -to 00:00:20.000&#x0a;  -c copy&#x0a;  output.mp4"
                                                             FontFamily="Consolas"
                                                             FontSize="11"
                                                             Foreground="#A6E22E"
                                                             Background="#1E1E1E"
                                                             BorderThickness="0"
                                                             TextWrapping="Wrap"
                                                             IsReadOnly="True"
                                                             AcceptsReturn="True"
                                                             MinHeight="80"
                                                             Style="{x:Null}">
                                                        <TextBox.Template>
                                                            <ControlTemplate TargetType="TextBox">
                                                                <Border x:Name="border" Background="#1E1E1E" BorderBrush="Transparent" BorderThickness="0">
                                                                    <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" Background="#1E1E1E"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </TextBox.Template>
                                                    </TextBox>
                                                </ScrollViewer>
                                            </Border>
                                            
                                            <TextBlock Text="命令说明:" 
                                                       Foreground="#999" FontSize="11" Margin="0,10,0,5"/>
                                            <Border Background="#37474F" Padding="8" CornerRadius="3">
                                                <TextBlock Name="CommandDescriptionBox"
                                                           Text="• 输入文件: input.mp4&#x0a;• 起始时间: 00:00:10.000&#x0a;• 结束时间: 00:00:20.000&#x0a;• 编码模式: 快速复制 (无损)&#x0a;• 输出文件: output.mp4"
                                                           Foreground="#E0E0E0"
                                                           FontSize="10"
                                                           TextWrapping="Wrap"/>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                                
                                <!-- 操作按钮 -->
                                <Border Grid.Row="1"
                                        Background="#2D2D30"
                                        BorderBrush="#3F3F46" 
                                        BorderThickness="0,1,0,0" Padding="8">
                                    <UniformGrid Rows="1" Columns="3">
                                        <Button Name="BtnCopyCommand" Content="📋 复制命令" Height="32" Margin="2" FontSize="11" 
                                                Click="BtnCopyCommand_Click" ToolTip="将命令复制到剪贴板"/>
                                        <Button Name="BtnEditCommand" Content="✏️ 编辑命令" Height="32" Margin="2" FontSize="11" 
                                                Click="BtnEditCommand_Click" ToolTip="切换命令编辑模式"/>
                                        <Button Name="BtnRefreshPreview" Content="🔄 刷新预览" Height="32" Margin="2" FontSize="11" 
                                                Click="BtnRefreshPreview_Click" ToolTip="重新生成命令预览"/>
                                    </UniformGrid>
        </Border>
                            </Grid>
                        </TabItem>

                        <!-- 标签页3：任务监控 -->
                        <TabItem x:Name="TaskMonitorTabItem" Header="📊 任务监控">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ListView Name="TaskProgressListView"
                                          Margin="0,0,0,12"
                                          BorderBrush="#333"
                                          BorderThickness="1"
                                          Background="#121212">
                                    <ListView.View>
                                        <GridView AllowsColumnReorder="True">
                                            <GridViewColumn Header="类型" DisplayMemberBinding="{Binding TaskType}" Width="80"/>
                                            <GridViewColumn Header="任务" DisplayMemberBinding="{Binding TaskName}" Width="150"/>
                                            <GridViewColumn Header="状态" DisplayMemberBinding="{Binding Status}" Width="120"/>
                                            <GridViewColumn Header="进度" Width="160">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <ProgressBar Value="{Binding ProgressValue}" Minimum="0" Maximum="100" Width="110" Height="12" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding ProgressText}" FontFamily="Consolas" FontSize="11"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="说明" DisplayMemberBinding="{Binding Detail}" Width="240"/>
                                            <GridViewColumn Header="开始时间" DisplayMemberBinding="{Binding StartTimeText}" Width="120"/>
                                            <GridViewColumn Header="耗时" DisplayMemberBinding="{Binding DurationText}" Width="90"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Name="BtnClearFinishedTasks"
                                            Content="清除已完成任务"
                                            Width="150"
                                            Click="BtnClearFinishedTasks_Click"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="FfmpegLogTabItem" Header="📜 FFmpeg日志">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0"
                                        Background="#0F111A"
                                        BorderBrush="#333"
                                        BorderThickness="1"
                                        Padding="10">
                                    <TextBox Name="FfmpegLogOutputBox"
                                             FontFamily="Consolas"
                                             FontSize="10"
                                             Background="#0F111A"
                                             Foreground="#D5DBE3"
                                             BorderThickness="0"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             Style="{x:Null}"
                                             Text="FFmpeg实时日志输出..."/>
                                </Border>
                                <Border Grid.Row="1"
                                        Background="#2D2D30"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="0,1,0,0"
                                        Padding="8">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Name="BtnClearFfmpegLog"
                                                Content="🗑️ 清空FFmpeg日志"
                                                Width="140"
                                                Height="28"
                                                FontSize="10"
                                                Click="BtnClearFfmpegLog_Click"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
            </Grid>
            
            <!-- ==================== 底部状态栏（增强版）==================== -->
            <StatusBar x:Name="BottomStatusBar"
                       Grid.Row="1"
                       Background="{DynamicResource Brush.StatusBackground}"
                       BorderBrush="{DynamicResource Brush.PanelBorder}"
                       BorderThickness="0,1,0,0"
                       Foreground="{DynamicResource Brush.StatusForeground}"
                       Height="28">
                <!-- 左侧：当前状态信息 -->
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Name="StatusIcon" 
                                   Text="✓" 
                                   FontSize="12" 
                                   Foreground="{DynamicResource Brush.AccentPrimary}" 
                                   Margin="10,0,5,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Name="StatusBarText" 
                                   Text="就绪" 
                                   VerticalAlignment="Center" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource Brush.StatusForeground}"/>
                    </StackPanel>
                </StatusBarItem>
                
                <Separator Margin="5,3"/>
                
                <!-- 文件统计 -->
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁" FontSize="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                        <TextBlock Name="StatusFileCount" 
                                   Text="文件: 0" 
                                   VerticalAlignment="Center" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource Brush.StatusForeground}"/>
                    </StackPanel>
                </StatusBarItem>
                
                <Separator Margin="5,3"/>
                
                <!-- 片段统计 -->
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" FontSize="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                        <TextBlock Name="StatusSegmentCount" 
                                   Text="{Binding ClipManager.ClipCount, StringFormat='片段: {0}'}" 
                                   VerticalAlignment="Center" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource Brush.StatusForeground}"/>
                    </StackPanel>
                </StatusBarItem>
                
                <Separator Margin="5,3"/>
                
                <!-- 总时长 -->
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏱️" FontSize="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                        <TextBlock Name="StatusDuration" 
                                   Text="时长: 00:00:00" 
                                   VerticalAlignment="Center" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource Brush.StatusForeground}"/>
                    </StackPanel>
                </StatusBarItem>
                
                <Separator Margin="5,3"/>
                
                <!-- 当前任务 -->
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️" FontSize="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                        <TextBlock Name="StatusCurrentTask" 
                                   Text="空闲" 
                                   VerticalAlignment="Center" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource Brush.StatusForeground}"/>
                    </StackPanel>
                </StatusBarItem>
                
                <!-- 右侧：系统资源和版本信息 -->
                <StatusBarItem HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <!-- CPU使用率 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                            <TextBlock Text="💻" FontSize="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                            <TextBlock Name="StatusCPU" 
                                       Text="CPU: 0%" 
                                       VerticalAlignment="Center" 
                                       FontSize="11" 
                                       Foreground="{DynamicResource Brush.StatusForeground}"/>
                        </StackPanel>
                        
                        <Separator Margin="0,3,10,3"/>
                        
                        <!-- 内存使用 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                            <TextBlock Text="🧠" FontSize="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                            <TextBlock Name="StatusMemory" 
                                       Text="内存: 0 MB" 
                                       VerticalAlignment="Center" 
                                       FontSize="11" 
                                       Foreground="{DynamicResource Brush.StatusForeground}"/>
                        </StackPanel>
                        
                        <Separator Margin="0,3,10,3"/>
                        
                        <!-- 磁盘空间 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                            <TextBlock Text="💾" FontSize="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                            <TextBlock Name="StatusDiskSpace" 
                                       Text="可用: 0 GB" 
                                       VerticalAlignment="Center" 
                                       FontSize="11" 
                                       Foreground="{DynamicResource Brush.StatusForeground}"
                                       ToolTip="输出目录剩余空间"/>
                        </StackPanel>
                        
                        <Separator Margin="0,3,10,3"/>
                        
                        <!-- FFmpeg版本 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                            <TextBlock Text="🎬" FontSize="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                            <TextBlock Name="StatusFFmpegVersion" 
                                       Text="FFmpeg: 未检测到" 
                                       VerticalAlignment="Center" 
                                       FontSize="11" 
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       ToolTip="FFmpeg版本信息"/>
                        </StackPanel>
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>

        </Grid>

        <!-- Toast通知容器 (覆盖在所有内容之上,避免被状态栏遮挡) -->
        <Grid Name="ToastContainer" 
              Panel.ZIndex="999"
              IsHitTestVisible="False"
              VerticalAlignment="Bottom"
              HorizontalAlignment="Center"
              Margin="0,0,0,80"/>
    </DockPanel>
</Window>
